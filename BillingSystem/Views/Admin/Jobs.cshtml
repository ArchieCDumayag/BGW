@model IReadOnlyList<JobTicket>
@{
    ViewData["Title"] = "Jobs";
    var clients = ViewBag.Clients as IReadOnlyList<Client> ?? Array.Empty<Client>();
    var technicians = ViewBag.Technicians as IReadOnlyList<Technician> ?? Array.Empty<Technician>();
}

<h1 class="page-title h3 mb-3">Installation & Repair Jobs</h1>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Create job</div>
    <div class="card-body">
        <form asp-action="AddJob" method="post" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label">Client</label>
                <select class="form-select" name="ClientId" required>
                    <option value="">Choose client</option>
                    @foreach (var client in clients)
                    {
                        <option value="@client.Id">@client.Name - @client.Area @client.Zone</option>
                    }
                </select>
            </div>
            <div class="col-md-2"><label class="form-label">Type</label><select class="form-select" name="Type"><option>Repair</option><option>Installation</option><option>Collection</option></select></div>
            <div class="col-md-2">
                <label class="form-label">Technician</label>
                <select class="form-select" name="TechnicianId">
                    <option value="">Unassigned</option>
                    @foreach (var technician in technicians)
                    {
                        <option value="@technician.Id">@technician.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2"><label class="form-label">Schedule</label><input class="form-control" name="ScheduledOn" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-primary mt-md-4">Create job</button></div>
            <div class="col-12"><label class="form-label">Remarks</label><input class="form-control" name="Remarks" /></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>Date</th><th>Type</th><th>Client</th><th>Technician</th><th>Status</th><th>Remarks</th></tr></thead>
                <tbody>
                @foreach (var job in Model)
                {
                    var clientName = clients.FirstOrDefault(c => c.Id == job.ClientId)?.Name ?? $"Client #{job.ClientId}";
                    var technicianName = technicians.FirstOrDefault(t => t.Id == job.TechnicianId)?.Name ?? "Unassigned";
                    var badgeClass = job.Status.Equals("Done", StringComparison.OrdinalIgnoreCase) ? "text-bg-success" : "text-bg-primary";
                    <tr>
                        <td>@job.ScheduledOn</td>
                        <td>@job.Type</td>
                        <td class="fw-medium">@clientName</td>
                        <td>@technicianName</td>
                        <td><span class="badge rounded-pill @badgeClass">@job.Status</span></td>
                        <td>@job.Remarks</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
