@model BillingData
@{
    ViewData["Title"] = "Assign Collector";
    var collectors = Model.UserAccounts
        .Where(u => u.IsActive && u.Role.Equals("Collector", StringComparison.OrdinalIgnoreCase))
        .OrderBy(u => u.DisplayName)
        .ThenBy(u => u.Username)
        .ToList();
    var clients = Model.Clients.OrderBy(c => c.Area).ThenBy(c => c.Name).ToList();
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Assign Collector</h1>
        <p class="text-body-secondary mb-0">Assign collectors to clients or areas for payment collection.</p>
    </div>
    <span class="badge text-bg-light border">@Model.CollectorAssignments.Count assignments</span>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">New assignment</div>
    <div class="card-body">
        <form asp-action="SaveCollectorAssignment" method="post" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label">Client</label>
                <select class="form-select" name="ClientId">
                    <option value="0">Area assignment only</option>
                    @foreach (var client in clients)
                    {
                        <option value="@client.Id">@client.Name - @client.Area</option>
                    }
                </select>
            </div>
            <div class="col-lg-3">
                <label class="form-label">Collector account</label>
                <select class="form-select" name="CollectorUserId">
                    <option value="">Manual collector name</option>
                    @foreach (var collector in collectors)
                    {
                        <option value="@collector.Id">@(string.IsNullOrWhiteSpace(collector.DisplayName) ? collector.Username : collector.DisplayName)</option>
                    }
                </select>
            </div>
            <div class="col-lg-3"><label class="form-label">Collector Name</label><input class="form-control" name="CollectorName" /></div>
            <div class="col-md-2"><label class="form-label">Area</label><input class="form-control" name="AreaName" /></div>
            <div class="col-md-3"><label class="form-label">Assigned On</label><input class="form-control" name="AssignedOn" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-7"><label class="form-label">Remarks</label><input class="form-control" name="Remarks" /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-primary mt-md-4">Assign</button></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>Date</th><th>Collector</th><th>Client</th><th>Area</th><th>Status</th><th>Remarks</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                @if (!Model.CollectorAssignments.Any())
                {
                    <tr><td colspan="7" class="text-center text-secondary py-4">No collector assignments yet.</td></tr>
                }
                @foreach (var assignment in Model.CollectorAssignments.OrderByDescending(a => a.AssignedOn))
                {
                    var client = Model.Clients.FirstOrDefault(c => c.Id == assignment.ClientId);
                    <tr>
                        <td>@assignment.AssignedOn</td>
                        <td class="fw-semibold">@assignment.CollectorName</td>
                        <td>@(client?.Name ?? "Area assignment")</td>
                        <td>@assignment.AreaName</td>
                        <td><span class="badge rounded-pill @(assignment.IsActive ? "text-bg-success" : "text-bg-secondary")">@(assignment.IsActive ? "Active" : "Inactive")</span></td>
                        <td>@assignment.Remarks</td>
                        <td class="text-end">
                            <form asp-action="DeleteCollectorAssignment" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@assignment.Id" />
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
