@model IReadOnlyList<Payment>
@{
    var clientMap = ViewBag.ClientMap as IReadOnlyDictionary<int, Client> ?? new Dictionary<int, Client>();
    var paymentTableTitle = ViewBag.PaymentTableTitle as string ?? "Payment history";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">@paymentTableTitle</span>
        <span class="badge text-bg-light border">@Model.Count records</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Date</th><th>Client</th><th>Amount</th><th>Method</th><th>Reference</th><th>Collector</th><th>Remarks</th></tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var methodBadge = item.Method.Contains("gcash", StringComparison.OrdinalIgnoreCase) ? "bg-blue-lt" :
                        item.Method.Contains("cash", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" : "bg-secondary-lt";
                    clientMap.TryGetValue(item.ClientId, out var client);
                    <tr class="@(client is null ? "" : "payment-client-row")"
                        data-customer-account-url="@(client is null ? "" : Url.Action("CustomerAccount", new { id = client.Id }))"
                        tabindex="@(client is null ? null : "0")"
                        role="@(client is null ? null : "link")"
                        title="@(client is null ? "" : "Open customer account")">
                        <td>@item.PaidOn</td>
                        <td>
                            @if (client is not null)
                            {
                                <span class="fw-medium">@client.Name</span>
                                <div class="small text-secondary">@client.PppoeUsername</div>
                            }
                            else
                            {
                                <span class="text-secondary">Unmatched client #@item.ClientId</span>
                            }
                        </td>
                        <td>PHP @item.Amount.ToString("N0")</td>
                        <td><span class="badge @methodBadge">@item.Method</span></td>
                        <td>@item.ReferenceNumber</td>
                        <td>@item.CollectedBy</td>
                        <td>@item.Remarks</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll(".payment-client-row").forEach(function (row) {
        row.style.cursor = "pointer";

        row.addEventListener("click", function (event) {
            if (event.target.closest("button, a, input, select, textarea, label")) {
                return;
            }

            if (row.dataset.customerAccountUrl) {
                window.location.href = row.dataset.customerAccountUrl;
            }
        });

        row.addEventListener("keydown", function (event) {
            if (event.key !== "Enter" && event.key !== " ") {
                return;
            }

            if (row.dataset.customerAccountUrl) {
                event.preventDefault();
                window.location.href = row.dataset.customerAccountUrl;
            }
        });
    });
</script>
