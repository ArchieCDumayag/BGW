@model IReadOnlyList<Payment>
@{
    var clientMap = ViewBag.ClientMap as IReadOnlyDictionary<int, Client> ?? new Dictionary<int, Client>();
    var paymentTableTitle = ViewBag.PaymentTableTitle as string ?? "Payment history";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">@paymentTableTitle</span>
        <span class="badge text-bg-light border">@Model.Count records</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Date</th><th>Client</th><th>Amount</th><th>Method</th><th>Reference</th><th>Collector</th><th>Remarks</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var methodBadge = item.Method.Contains("gcash", StringComparison.OrdinalIgnoreCase) ? "bg-blue-lt" :
                        item.Method.Contains("cash", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" : "bg-secondary-lt";
                    clientMap.TryGetValue(item.ClientId, out var client);
                    <tr>
                        <td>@item.PaidOn</td>
                        <td>
                            @if (client is not null)
                            {
                                <a class="fw-medium text-reset" asp-action="ClientHistory" asp-route-id="@client.Id">@client.Name</a>
                                <div class="small text-secondary">@client.PppoeUsername</div>
                            }
                            else
                            {
                                <span class="text-secondary">Unmatched client #@item.ClientId</span>
                            }
                        </td>
                        <td>PHP @item.Amount.ToString("N0")</td>
                        <td><span class="badge @methodBadge">@item.Method</span></td>
                        <td>@item.ReferenceNumber</td>
                        <td>@item.CollectedBy</td>
                        <td>@item.Remarks</td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="ti ti-files me-1"></i>Statements
                                </button>
                                <div class="dropdown-menu dropdown-menu-end">
                                    @if (client is not null)
                                    {
                                        <a class="dropdown-item" asp-action="ClientHistory" asp-route-id="@client.Id">
                                            <i class="ti ti-file-description me-2"></i>Account statement
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="dropdown-item disabled">
                                            <i class="ti ti-file-description me-2"></i>Account statement
                                        </span>
                                    }
                                    <a class="dropdown-item" asp-action="PaymentReceipt" asp-route-id="@item.Id">
                                        <i class="ti ti-file-invoice me-2"></i>Billing statement
                                    </a>
                                    <a class="dropdown-item" asp-action="PaymentReceipt" asp-route-id="@item.Id">
                                        <i class="ti ti-receipt me-2"></i>Thermal receipt
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
