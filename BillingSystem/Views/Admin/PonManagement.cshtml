@model IReadOnlyList<OltDevice>
@{
    ViewData["Title"] = "PON Management";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">PON Management</h1>
        <p class="text-body-secondary mb-0">OLT inventory by technology, site, and total PON ports.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#addOltForm">
        <i class="ti ti-plus me-1"></i>Add OLT
    </button>
</div>

<div class="collapse show mb-3" id="addOltForm">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="SaveOlt" method="post" class="row g-3">
                <div class="col-lg-3"><label class="form-label">OLT Name</label><input class="form-control" name="OltName" required /></div>
                <div class="col-md-2">
                    <label class="form-label">Technology</label>
                    <select class="form-select" name="Technology"><option>Gpon</option><option>Epon</option></select>
                </div>
                <div class="col-lg-3"><label class="form-label">Site</label><input class="form-control" name="Site" /></div>
                <div class="col-md-2"><label class="form-label">Total PON Ports</label><input class="form-control" name="TotalPonPorts" type="number" min="0" /></div>
                <div class="col-md-2 d-grid"><button class="btn btn-primary mt-md-4">Add OLT</button></div>
            </form>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>OLT Name</th><th>Technology</th><th>Site</th><th>Total PON Ports</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-secondary py-4">No OLT records yet.</td></tr>
                }
                @foreach (var olt in Model)
                {
                    <tr>
                        <td class="fw-semibold">@olt.OltName</td>
                        <td><span class="badge text-bg-purple-lt">@olt.Technology</span></td>
                        <td>@olt.Site</td>
                        <td>@olt.TotalPonPorts</td>
                        <td class="text-end">
                            <form asp-action="DeleteOlt" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@olt.Id" />
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
