@model IReadOnlyList<Payment>
@{
    ViewData["Title"] = "Recent Paid Bills";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Recent Paid Bills</h1>
        <p class="text-body-secondary mb-0">Latest paid bills with receipt links.</p>
    </div>
    <a class="btn btn-primary" asp-action="Payments">
        <i class="ti ti-cash me-1"></i>Add payment
    </a>
</div>

<partial name="_PaymentsTable" model="Model" />
