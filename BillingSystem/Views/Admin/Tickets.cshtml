@model BillingData
@{
    ViewData["Title"] = "Tickets";
    var clients = Model.Clients.OrderBy(c => c.Name).ToList();
    var technicians = Model.Technicians.Where(t => t.IsActive).OrderBy(t => t.Name).ToList();
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Tickets</h1>
        <p class="text-body-secondary mb-0">Create and monitor customer support tickets.</p>
    </div>
    <span class="badge text-bg-light border">@Model.Tickets.Count tickets</span>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Create ticket</div>
    <div class="card-body">
        <form asp-action="AddTicket" method="post" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label">Client</label>
                <select class="form-select" name="ClientId" required>
                    <option value="">Choose client</option>
                    @foreach (var client in clients)
                    {
                        <option value="@client.Id">@client.Name - @client.Area</option>
                    }
                </select>
            </div>
            <div class="col-lg-4"><label class="form-label">Subject</label><input class="form-control" name="Subject" required /></div>
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select class="form-select" name="Type"><option>Repair</option><option>Installation</option><option>Billing</option><option>Outage</option></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Priority</label>
                <select class="form-select" name="Priority"><option>Normal</option><option>High</option><option>Urgent</option></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Assigned To</label>
                <select class="form-select" name="AssignedTo">
                    <option value="">Unassigned</option>
                    @foreach (var technician in technicians)
                    {
                        <option>@technician.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3"><label class="form-label">Created On</label><input class="form-control" name="CreatedOn" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-4"><label class="form-label">Remarks</label><input class="form-control" name="Remarks" /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-primary mt-md-4">Create ticket</button></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>Date</th><th>Client</th><th>Subject</th><th>Type</th><th>Priority</th><th>Status</th><th>Assigned</th><th>Remarks</th></tr></thead>
                <tbody>
                @if (!Model.Tickets.Any())
                {
                    <tr><td colspan="8" class="text-center text-secondary py-4">No tickets yet.</td></tr>
                }
                @foreach (var ticket in Model.Tickets.OrderByDescending(t => t.CreatedOn).ThenByDescending(t => t.Id))
                {
                    var clientName = Model.Clients.FirstOrDefault(c => c.Id == ticket.ClientId)?.Name ?? $"Client #{ticket.ClientId}";
                    var priorityClass = ticket.Priority.Equals("Urgent", StringComparison.OrdinalIgnoreCase) ? "text-bg-danger" :
                        ticket.Priority.Equals("High", StringComparison.OrdinalIgnoreCase) ? "text-bg-warning" : "text-bg-secondary";
                    <tr>
                        <td>@ticket.CreatedOn</td>
                        <td class="fw-semibold">@clientName</td>
                        <td>@ticket.Subject</td>
                        <td>@ticket.Type</td>
                        <td><span class="badge @priorityClass">@ticket.Priority</span></td>
                        <td>@ticket.Status</td>
                        <td>@ticket.AssignedTo</td>
                        <td>@ticket.Remarks</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
