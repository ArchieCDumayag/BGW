@model IReadOnlyList<ServicePlan>
@{
    ViewData["Title"] = "Plans";
    var clients = ViewBag.Clients as IReadOnlyList<Client> ?? Array.Empty<Client>();
    int CountClients(ServicePlan plan) => clients.Count(c =>
        c.PlanAmount == plan.Price &&
        (c.BillingType ?? "").Equals(plan.Type, StringComparison.OrdinalIgnoreCase));
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Plans</h1>
        <p class="text-body-secondary mb-0">Plan name, price, subscriber count, and billing type.</p>
    </div>
    <span class="badge text-bg-light border">@Model.Count plans</span>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Add plan</div>
    <div class="card-body">
        <form asp-action="SavePlan" method="post" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label">Plan Name</label>
                <input class="form-control" name="PlanName" placeholder="Example: 800 Mbps Plan" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Price</label>
                <input class="form-control" name="Price" type="number" min="0" step="0.01" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Type</label>
                <select class="form-select" name="Type">
                    <option>Prepaid</option>
                    <option>Postpaid</option>
                    <option>XentroNet</option>
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-primary mt-md-4">Add plan</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Plan Name</th><th>Price</th><th>Total Clients</th><th>Type</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-secondary py-4">No plans added yet.</td></tr>
                }
                @foreach (var plan in Model)
                {
                    <tr>
                        <td class="fw-semibold">@plan.PlanName</td>
                        <td>PHP @plan.Price.ToString("N0")</td>
                        <td>@CountClients(plan)</td>
                        <td><span class="badge text-bg-blue-lt">@plan.Type</span></td>
                        <td class="text-end">
                            <form asp-action="DeletePlan" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@plan.Id" />
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
