@model IReadOnlyList<Expense>
@{
    ViewData["Title"] = "Expenses";
}

<h1 class="page-title h3 mb-3">Expenses</h1>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Add expense</div>
    <div class="card-body">
        <form asp-action="AddExpense" method="post" class="row g-3 align-items-end">
            <div class="col-md-2"><label class="form-label">Date</label><input class="form-control" name="SpentOn" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-3"><label class="form-label">Category</label><input class="form-control" name="Category" value="Operations" /></div>
            <div class="col-md-4"><label class="form-label">Description</label><input class="form-control" name="Description" required /></div>
            <div class="col-md-2"><label class="form-label">Amount</label><input class="form-control" name="Amount" type="number" step="0.01" required /></div>
            <div class="col-md-1 d-grid"><button class="btn btn-primary">Add</button></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th></tr></thead>
                <tbody>
                @foreach (var expense in Model)
                {
                    <tr><td>@expense.SpentOn</td><td>@expense.Category</td><td>@expense.Description</td><td>PHP @expense.Amount.ToString("N0")</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
