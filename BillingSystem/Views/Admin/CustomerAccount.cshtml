@model CustomerAccountViewModel
@{
    ViewData["Title"] = "View Customer Account";
    var client = Model.Client;
    var billingRule = Model.BillingRule;
    var invariantCulture = System.Globalization.CultureInfo.InvariantCulture;
    var statusBadge = client.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" :
        client.Status.Equals("DC", StringComparison.OrdinalIgnoreCase) ? "bg-red-lt" : "bg-secondary-lt";
    var hasCoordinates = client.Latitude.HasValue && client.Longitude.HasValue;
    var coordinateText = hasCoordinates
        ? $"{client.Latitude!.Value.ToString("0.######", invariantCulture)}, {client.Longitude!.Value.ToString("0.######", invariantCulture)}"
        : "-";
    var mapQuery = hasCoordinates
        ? coordinateText
        : string.Join(" ", new[] { client.Address, client.Area, client.Zone }.Where(value => !string.IsNullOrWhiteSpace(value)));
    var accountMessage = TempData["CustomerAccountMessage"] as string;
    var accountError = TempData["CustomerAccountError"] as string;
    var currentMonth = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
    var currentMonthValue = currentMonth.ToString("yyyy-MM", invariantCulture);
    var currentBillingMonth = Model.BillingMonths.FirstOrDefault(month => month.Month == currentMonth);
    var currentBillAmount = currentBillingMonth?.BillAmount ?? client.Bills;
    var planOptions = new[] { 800m, 1000m, 1200m, 1500m };
    var paymentClientLabel = string.IsNullOrWhiteSpace(client.PppoeUsername)
        ? client.Name
        : $"{client.Name} - {client.PppoeUsername}";
    var suggestedPaymentAmount = currentBillAmount;
    var suggestedPaymentAmountValue = suggestedPaymentAmount > 0
        ? suggestedPaymentAmount.ToString("0.##", invariantCulture)
        : "";
    var paymentDateValue = DateTime.Today.ToString("yyyy-MM-dd", invariantCulture);
    var collectorName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">View Customer Account</h1>
        <p class="text-body-secondary mb-0">@client.Name</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-action="Clients">
            <i class="ti ti-arrow-left me-1"></i>Clients
        </a>
        <a class="btn btn-outline-primary" asp-action="AccountStatement" asp-route-id="@client.Id" asp-route-year="@Model.SelectedYear" target="_blank" rel="noopener">
            <i class="ti ti-file-description me-1"></i>Account
        </a>
        <a class="btn btn-outline-primary" asp-action="BillingStatement" asp-route-id="@client.Id" target="_blank" rel="noopener">
            <i class="ti ti-file-invoice me-1"></i>Billing
        </a>
        <a class="btn btn-outline-primary" asp-action="ThermalReceipt" asp-route-id="@client.Id" target="_blank" rel="noopener">
            <i class="ti ti-receipt me-1"></i>Thermal
        </a>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addCustomerPaymentModal">
            <i class="ti ti-cash me-1"></i>Payment
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(accountMessage))
{
    <div class="alert alert-success" role="alert">@accountMessage</div>
}

@if (!string.IsNullOrWhiteSpace(accountError))
{
    <div class="alert alert-danger" role="alert">@accountError</div>
}

<div class="modal modal-blur fade" id="addCustomerPaymentModal" tabindex="-1" aria-labelledby="addCustomerPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form asp-action="AddPayment" method="post" class="modal-content">
            <input type="hidden" name="ClientId" value="@client.Id" />
            <input type="hidden" name="returnToCustomerAccount" value="true" />
            <div class="modal-header">
                <h5 class="modal-title" id="addCustomerPaymentModalLabel">Add payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <label class="form-label">Client</label>
                        <input class="form-control" value="@paymentClientLabel" disabled />
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label">Date</label>
                        <input class="form-control" id="customerPaymentDate" name="PaidOn" type="date" value="@paymentDateValue" required />
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <label class="form-label">Amount</label>
                        <input class="form-control" id="customerPaymentAmount" name="Amount" type="number" min="0.01" step="0.01" value="@suggestedPaymentAmountValue" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Method</label>
                        <select class="form-select" name="Method">
                            <option>Cash</option>
                            <option>GCash</option>
                            <option>Bank</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Reference number</label>
                        <input class="form-control" name="ReferenceNumber" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Collected by</label>
                        <input class="form-control" name="CollectedBy" value="@collectorName" readonly />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <input class="form-control" name="Remarks" />
                    </div>
                    <div class="col-12">
                        <div id="customerPaymentRuleInfo"
                             class="alert @(billingRule.HasEarlyDiscount ? "alert-success" : "alert-info") mb-0"
                             data-billing-type="@billingRule.BillingType"
                             data-schedule="@billingRule.ScheduleLabel"
                             data-due="@billingRule.NextDueDate.ToString("MMM dd, yyyy")"
                             data-current-bill="@currentBillAmount.ToString("0.##", invariantCulture)"
                             data-has-discount="@billingRule.HasEarlyDiscount.ToString().ToLowerInvariant()"
                             data-discount="@billingRule.EarlyDiscountAmount.ToString("0.##", invariantCulture)"
                             data-deadline="@(billingRule.DiscountDeadline?.ToString("MMM dd, yyyy") ?? "")"
                             data-deadline-iso="@(billingRule.DiscountDeadline?.ToString("yyyy-MM-dd", invariantCulture) ?? "")"
                             role="alert"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="form-check me-auto">
                    <input class="form-check-input" id="customerPrintThermalAfterPayment" name="printThermal" type="checkbox" value="true" />
                    <label class="form-check-label" for="customerPrintThermalAfterPayment">Print thermal after saving</label>
                </div>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary">
                    <i class="ti ti-cash me-1"></i>Save payment
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal modal-blur fade" id="editPlanModal" tabindex="-1" aria-labelledby="editPlanModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <form asp-action="ChangeClientPlan" method="post" class="modal-content">
            <input type="hidden" name="id" value="@client.Id" />
            <input type="hidden" name="effectiveMonth" value="@currentMonthValue" />
            <div class="modal-header">
                <h5 class="modal-title" id="editPlanModalLabel">Edit plan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Plan amount</label>
                <div class="input-group">
                    <span class="input-group-text">PHP</span>
                    <select class="form-select" name="planAmount" aria-label="Plan amount" required>
                        @foreach (var planOption in planOptions)
                        {
                            <option value="@planOption.ToString("0.##", invariantCulture)" selected="@(client.PlanAmount == planOption)">
                                @planOption.ToString("N0")
                            </option>
                        }
                    </select>
                </div>
                <div class="small text-secondary mt-2">Effective @currentMonth.ToString("MMMM yyyy") onward</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary">
                    <i class="ti ti-device-floppy me-1"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal modal-blur fade" id="editCurrentBillModal" tabindex="-1" aria-labelledby="editCurrentBillModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <form asp-action="UpdateMonthlyBill" method="post" class="modal-content">
            <input type="hidden" name="id" value="@client.Id" />
            <input type="hidden" name="billingMonth" id="editCurrentBillMonth" />
            <input type="hidden" name="returnYear" value="@Model.SelectedYear" />
            <input type="hidden" name="discountAmount" id="editCurrentBillDiscountAmount" />
            <input type="hidden" name="discountRemarks" id="editCurrentBillDiscountRemarks" />
            <div class="modal-header">
                <h5 class="modal-title" id="editCurrentBillModalLabel">Edit current bill</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-secondary small mb-2" id="editCurrentBillMonthLabel"></div>
                <label class="form-label" for="editCurrentBillAmount">Bill amount</label>
                <div class="input-group">
                    <span class="input-group-text">PHP</span>
                    <input class="form-control text-end" id="editCurrentBillAmount" name="billAmount" type="number" min="0" step="0.01" required />
                </div>
                <div class="alert alert-warning py-2 mt-3 mb-0 d-none" id="xentronetDiscountTools">
                    <div class="small mb-2" id="xentronetDiscountText"></div>
                    <button class="btn btn-sm btn-warning w-100" type="button" id="applyXentronetDiscount">
                        <i class="ti ti-discount-2 me-1"></i>Apply discount
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary">
                    <i class="ti ti-device-floppy me-1"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row row-cards mb-3">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Customer Account</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-secondary fw-normal">Name</dt>
                    <dd class="col-sm-7 fw-semibold">@client.Name</dd>
                    <dt class="col-sm-5 text-secondary fw-normal">Contact Number</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(client.Contact) ? client.Contact : "-")</dd>
                    <dt class="col-sm-5 text-secondary fw-normal">Email</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(client.Email) ? client.Email : "-")</dd>
                    <dt class="col-sm-5 text-secondary fw-normal">Facebook Account</dt>
                    <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(client.FacebookAccount) ? client.FacebookAccount : "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary text-uppercase small">Financial Status</div>
                <div class="text-secondary small mt-2">Current Balance</div>
                <div class="h1 mb-0">PHP @Model.CurrentBalance.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-secondary text-uppercase small">Status</div>
                <div class="mt-3">
                    <span class="badge @statusBadge fs-4">@client.Status</span>
                </div>
                <div class="small text-secondary mt-2">Active / DC account state</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Account Information</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-secondary small">Type</div>
                <div class="fw-semibold">@client.BillingType</div>
            </div>
            <div class="col-md-4">
                <div class="text-secondary small">Plan</div>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <div class="fw-semibold">PHP @client.PlanAmount.ToString("N0")</div>
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#editPlanModal" title="Edit plan">
                        <i class="ti ti-edit"></i>
                    </button>
                </div>
                <div class="small text-secondary mt-1">Effective @currentMonth.ToString("MMMM yyyy") onward</div>
            </div>
            <div class="col-md-4">
                <div class="text-secondary small">Due</div>
                <div class="fw-semibold">@billingRule.ScheduleLabel</div>
                <div class="small text-secondary">@billingRule.NextDueDate.ToString("MMM dd, yyyy")</div>
            </div>
            <div class="col-md-4">
                <div class="text-secondary small">Area</div>
                <div class="fw-semibold">@client.Area @client.Zone</div>
                <div class="small text-secondary">@(!string.IsNullOrWhiteSpace(client.Address) ? client.Address : "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-secondary small">Coordinates with Google Map</div>
                <div class="fw-semibold">@coordinateText</div>
                @if (!string.IsNullOrWhiteSpace(mapQuery))
                {
                    <a class="btn btn-sm btn-outline-primary mt-2" href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(mapQuery)" target="_blank" rel="noopener">
                        <i class="ti ti-map-pin me-1"></i>Open map
                    </a>
                }
            </div>
            <div class="col-md-4">
                <div class="text-secondary small">Credit limit for auto disconnect</div>
                <div class="fw-semibold">@(client.CreditLimit > 0 ? $"PHP {client.CreditLimit:N0}" : "No limit set")</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <span class="fw-semibold">Payment History</span>
            <span class="badge text-bg-light border ms-2">@Model.SelectedYear - @Model.BillingMonths.Count monthly bills</span>
        </div>
        <form asp-action="CustomerAccount" method="get" class="d-flex align-items-center gap-2">
            <input type="hidden" name="id" value="@client.Id" />
            <label class="small text-secondary mb-0" for="paymentHistoryYear">Year</label>
            <select class="form-select form-select-sm" id="paymentHistoryYear" name="year" onchange="this.form.submit()">
                @foreach (var yearOption in Model.AvailableYears)
                {
                    <option value="@yearOption" selected="@(yearOption == Model.SelectedYear)">@yearOption</option>
                }
            </select>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Month</th>
                        <th class="text-end">Previous balance</th>
                        <th class="text-end">Advance</th>
                        <th class="text-end">Referral</th>
                        <th class="text-end">Bills</th>
                        <th class="text-end">Amount paid</th>
                        <th class="text-end">Balance</th>
                        <th>Status</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th>Remarks</th>
                        <th>Collector</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var bill in Model.BillingMonths)
                {
                    var billMonthValue = bill.Month.ToString("yyyy-MM", invariantCulture);
                    var billAmountValue = bill.BillAmount.ToString("0.##", invariantCulture);
                    var discountedBillValue = Math.Max(0, bill.BillAmount - BillingSystem.Services.BillingRules.XentronetEarlyDiscount).ToString("0.##", invariantCulture);
                    var discountAppliedValue = bill.DiscountAmount.ToString("0.##", invariantCulture);
                    var paymentBreakdownTooltip = bill.PaymentBreakdown.Count == 0
                        ? "No payment breakdown"
                        : string.Join(" | ", bill.PaymentBreakdown.Select(payment => $"{payment.PaidOn:MMM dd, yyyy}: PHP {payment.Amount:N0}"));
                    var billStatusClass = bill.Status.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" :
                        bill.Status.Equals("Balance", StringComparison.OrdinalIgnoreCase) ? "bg-yellow-lt" :
                        bill.Status.Equals("Unpaid", StringComparison.OrdinalIgnoreCase) ? "bg-red-lt" : "bg-secondary-lt";
                    <tr>
                        <td class="fw-medium">@bill.MonthLabel</td>
                        <td class="text-end">PHP @bill.Balance.ToString("N0")</td>
                        <td class="text-end">@(bill.Advance > 0 ? $"PHP {bill.Advance:N0}" : "-")</td>
                        <td class="text-end">
                            @if (bill.ReferralDiscount > 0 || !string.IsNullOrWhiteSpace(bill.ReferralNames))
                            {
                                <div>@(bill.ReferralDiscount > 0 ? $"PHP {bill.ReferralDiscount:N0}" : "-")</div>
                                @if (!string.IsNullOrWhiteSpace(bill.ReferralNames))
                                {
                                    <div class="small text-secondary">@bill.ReferralNames</div>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end align-items-center gap-2">
                                <span class="fw-semibold">PHP @bill.BillAmount.ToString("N0")</span>
                                <button class="btn btn-sm btn-outline-primary"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editCurrentBillModal"
                                        data-billing-month="@billMonthValue"
                                        data-month-label="@bill.MonthLabel"
                                        data-bill-amount="@billAmountValue"
                                        data-due-date="@bill.DueDate.ToString("MMM dd, yyyy")"
                                        data-billing-type="@client.BillingType"
                                        data-discount="@BillingSystem.Services.BillingRules.XentronetEarlyDiscount.ToString("0.##", invariantCulture)"
                                        data-discounted-bill="@discountedBillValue"
                                        data-discount-applied="@discountAppliedValue"
                                        title="Edit current bill"
                                        aria-label="Edit current bill for @bill.MonthLabel">
                                    <i class="ti ti-edit"></i>
                                </button>
                            </div>
                            @if (bill.DiscountAmount > 0)
                            {
                                <div class="small text-success mt-1">
                                    Discount PHP @bill.DiscountAmount.ToString("N0")
                                    @if (!string.IsNullOrWhiteSpace(bill.DiscountNote))
                                    {
                                        <span>- @bill.DiscountNote</span>
                                    }
                                </div>
                            }
                        </td>
                        <td class="text-end">
                            <span class="text-decoration-underline text-decoration-dotted"
                                  tabindex="0"
                                  data-bs-toggle="tooltip"
                                  data-bs-trigger="hover focus"
                                  data-bs-placement="top"
                                  data-bs-title="@paymentBreakdownTooltip"
                                  aria-label="Billing breakdown for @bill.MonthLabel">
                                PHP @bill.AmountPaid.ToString("N0")
                            </span>
                        </td>
                        <td class="text-end">@(bill.RemainingBalance > 0 ? $"PHP {bill.RemainingBalance:N0}" : "-")</td>
                        <td><span class="badge @billStatusClass">@bill.Status</span></td>
                        <td>@bill.Methods</td>
                        <td>@bill.References</td>
                        <td class="small text-secondary">@bill.Remarks</td>
                        <td>@bill.Collectors</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                if (window.bootstrap && window.bootstrap.Tooltip) {
                    new bootstrap.Tooltip(element);
                }
            });

            const paymentDate = document.getElementById("customerPaymentDate");
            const amountInput = document.getElementById("customerPaymentAmount");
            const info = document.getElementById("customerPaymentRuleInfo");

            if (!paymentDate || !amountInput || !info) {
                return;
            }

            let lastSuggestedAmount = amountInput.value;

            function money(value) {
                return new Intl.NumberFormat("en-PH", { maximumFractionDigits: 0 }).format(Number(value || 0));
            }

            function updatePaymentSuggestion() {
                const hasDiscount = info.dataset.hasDiscount === "true";
                const currentBill = Number(info.dataset.currentBill || 0);
                const discount = Number(info.dataset.discount || 0);
                const paidBeforeDeadline = hasDiscount
                    && paymentDate.value
                    && info.dataset.deadlineIso
                    && paymentDate.value < info.dataset.deadlineIso;
                const suggestedBill = currentBill;

                info.className = "alert " + (hasDiscount && paidBeforeDeadline ? "alert-warning" : "alert-info") + " mb-0";
                info.innerHTML = hasDiscount && paidBeforeDeadline
                    ? "<strong>Xentronet discount eligible:</strong> PHP " + money(discount) + " before " + info.dataset.deadline + ". Admin can apply it by editing the current bill. Suggested payment: <strong>PHP " + money(suggestedBill) + "</strong>."
                    : hasDiscount
                    ? "<strong>Xentronet:</strong> prepaid every 1st day. Discount is available only before " + info.dataset.deadline + " when admin applies it. Suggested payment: <strong>PHP " + money(suggestedBill) + "</strong>."
                    : "<strong>" + info.dataset.billingType + ":</strong> " + info.dataset.schedule + ". Next due: " + info.dataset.due + ". Suggested amount: <strong>PHP " + money(suggestedBill) + "</strong>.";

                if ((!amountInput.value || amountInput.value === lastSuggestedAmount) && suggestedBill > 0) {
                    amountInput.value = suggestedBill.toFixed(2);
                    lastSuggestedAmount = amountInput.value;
                }
            }

            paymentDate.addEventListener("change", updatePaymentSuggestion);
            updatePaymentSuggestion();

            const editCurrentBillModal = document.getElementById("editCurrentBillModal");
            if (editCurrentBillModal) {
                editCurrentBillModal.addEventListener("show.bs.modal", function (event) {
                    const button = event.relatedTarget;
                    const billingMonthInput = document.getElementById("editCurrentBillMonth");
                    const billAmountInput = document.getElementById("editCurrentBillAmount");
                    const monthLabel = document.getElementById("editCurrentBillMonthLabel");
                    const discountTools = document.getElementById("xentronetDiscountTools");
                    const discountText = document.getElementById("xentronetDiscountText");
                    const applyDiscount = document.getElementById("applyXentronetDiscount");
                    const discountAmountInput = document.getElementById("editCurrentBillDiscountAmount");
                    const discountRemarksInput = document.getElementById("editCurrentBillDiscountRemarks");

                    if (!button || !billingMonthInput || !billAmountInput || !monthLabel) {
                        return;
                    }

                    billingMonthInput.value = button.dataset.billingMonth || "";
                    billAmountInput.value = button.dataset.billAmount || "";
                    monthLabel.textContent = button.dataset.monthLabel || "";

                    const isXentronet = (button.dataset.billingType || "").toLowerCase() === "xentronet";
                    const discount = Number(button.dataset.discount || 0);
                    const discountedBill = Number(button.dataset.discountedBill || 0);
                    const existingDiscount = Number(button.dataset.discountApplied || 0);
                    const dueDate = button.dataset.dueDate || "the due date";
                    if (discountAmountInput) {
                        discountAmountInput.value = isXentronet
                            ? existingDiscount > 0 ? existingDiscount.toFixed(2) : "0"
                            : "";
                    }
                    if (discountRemarksInput) {
                        discountRemarksInput.value = isXentronet && existingDiscount > 0
                            ? "Xentronet discount approved by admin."
                            : "";
                    }

                    if (discountTools && discountText && applyDiscount) {
                        if (isXentronet && existingDiscount > 0) {
                            discountTools.classList.remove("d-none");
                            applyDiscount.classList.add("d-none");
                            discountText.textContent = "PHP " + money(existingDiscount) + " discount already applied to this bill.";
                            applyDiscount.onclick = null;
                        } else if (isXentronet && discount > 0) {
                            discountTools.classList.remove("d-none");
                            discountText.textContent = "Eligible before " + dueDate + ": PHP " + money(discount) + ". Admin decides if this bill uses it.";
                            applyDiscount.classList.remove("d-none");
                            applyDiscount.onclick = function () {
                                billAmountInput.value = discountedBill.toFixed(2);
                                if (discountAmountInput) {
                                    discountAmountInput.value = discount.toFixed(2);
                                }
                                if (discountRemarksInput) {
                                    discountRemarksInput.value = "Xentronet PHP " + money(discount) + " discount approved by admin.";
                                }
                            };
                        } else {
                            discountTools.classList.add("d-none");
                            applyDiscount.classList.remove("d-none");
                            applyDiscount.onclick = null;
                        }
                    }
                });
            }
        });
    </script>
}
