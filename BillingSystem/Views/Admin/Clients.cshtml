@model IReadOnlyList<Client>
@{
    ViewData["Title"] = "Clients";
    var areas = ViewBag.Areas as IReadOnlyList<string> ?? Array.Empty<string>();
    var types = ViewBag.Types as IReadOnlyList<string> ?? Array.Empty<string>();
    var billingRules = ViewBag.ClientBillingRules as IReadOnlyDictionary<int, BillingRuleInfo> ?? new Dictionary<int, BillingRuleInfo>();
    var deleteCaptchas = ViewBag.ClientDeleteCaptchas as IReadOnlyDictionary<int, string> ?? new Dictionary<int, string>();
    var referralClients = ViewBag.ReferralClients as IReadOnlyList<Client> ?? Model;
    var sort = ViewBag.Sort as string ?? "";
    var clientMessage = TempData["ClientMessage"] as string;
    var clientError = TempData["ClientError"] as string;
    var nextAccountNumber = ViewBag.NextAccountNumber as string ?? "1";
    var todayValue = DateTime.Today.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);
    var planOptions = new[] { 800m, 1000m, 1200m, 1500m };
    var areaOptions = new[] { "Asassi", "Bagunot", "Bunugan", "Canagatan", "Carupian", "Ibulo", "Poblacion", "San Vicente", "Taguing", "Temblique" };
    var zoneOptions = Enumerable.Range(1, 7).Select(number => $"Zone {number}").ToArray();
    var monthOptions = Enumerable.Range(1, 12)
        .Select(month => new DateTime(DateTime.Today.Year, month, 1))
        .ToArray();
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Clients</h1>
        <p class="text-body-secondary mb-0">Manage subscriber records imported from the client list.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#clearClientsModal">
            <i class="ti ti-trash me-1"></i>Clear records
        </button>
        <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#clientForm" aria-expanded="false" aria-controls="clientForm">
            Add client
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(clientMessage))
{
    <div class="alert alert-success" role="alert">@clientMessage</div>
}

@if (!string.IsNullOrWhiteSpace(clientError))
{
    <div class="alert alert-danger" role="alert">@clientError</div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Replace client list</div>
    <div class="card-body">
        <div class="alert alert-warning py-2 mb-3" role="alert">
            Importing a yearly workbook replaces clients and imports payment history from BILLS, CASH, and GCASH sheets.
        </div>
        <form asp-action="ImportClientList" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Year</label>
                <input class="form-control" name="importYear" type="number" min="2000" max="2100" value="@DateTime.Today.Year" required />
            </div>
            <div class="col-md-7">
                <label class="form-label">Excel file</label>
                <input class="form-control" name="clientListFile" type="file" accept=".xlsx" required />
            </div>
            <div class="col-md-3 d-grid">
                <button class="btn btn-outline-danger" type="submit">
                    <i class="ti ti-file-spreadsheet me-1"></i>Replace clients
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Download client report</div>
    <div class="card-body">
        <form asp-action="DownloadClientReport" method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Year</label>
                <input class="form-control" name="reportYear" type="number" min="2000" max="2100" value="@DateTime.Today.Year" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Range</label>
                <select class="form-select" name="reportMonth">
                    <option value="">Year to current month</option>
                    @foreach (var monthOption in monthOptions)
                    {
                        <option value="@monthOption.Month">@monthOption.ToString("MMMM", System.Globalization.CultureInfo.InvariantCulture)</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-grid">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="ti ti-download me-1"></i>Download report
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input class="form-control" name="q" value="@ViewBag.Query" placeholder="Name, PPPoE, account" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="">All statuses</option>
                    <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
                    <option value="DC" selected="@(ViewBag.Status == "DC")">DC</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Area</label>
                <select class="form-select" name="area">
                    <option value="">All areas</option>
                    @foreach (var area in areas)
                    {
                        <option value="@area" selected="@(ViewBag.Area == area)">@area</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select class="form-select" name="type">
                    <option value="">All types</option>
                    @foreach (var type in types)
                    {
                        <option value="@type" selected="@(ViewBag.Type == type)">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Sort</label>
                <select class="form-select" name="sort">
                    <option value="" selected="@(sort == "")">Default (# A-Z)</option>
                    <option value="account-desc" selected="@(sort == "account-desc")"># Z-A</option>
                    <option value="name" selected="@(sort == "name")">Name</option>
                    <option value="type" selected="@(sort == "type")">Type</option>
                    <option value="status" selected="@(sort == "status")">Status</option>
                    <option value="area" selected="@(sort == "area")">Area</option>
                    <option value="pppoe" selected="@(sort == "pppoe")">PPPoE</option>
                </select>
            </div>
            <div class="col-md-1">
                <button class="btn btn-dark w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div id="clientForm" class="collapse mb-3">
    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white">New client</div>
        <div class="card-body">
            <form asp-action="SaveClient" method="post" class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Account #</label>
                    <input class="form-control" value="@nextAccountNumber" disabled />
                    <input type="hidden" name="AccountNumber" value="@nextAccountNumber" />
                </div>
                <div class="col-md-3"><label class="form-label">Client name</label><input class="form-control" name="Name" required /></div>
                <div class="col-md-2"><label class="form-label">Installation date</label><input class="form-control" name="DateInstalled" id="newDateInstalled" type="date" value="@todayValue" required /></div>
                <div class="col-md-2"><label class="form-label">Status</label><input class="form-control" name="Status" value="Active" /></div>
                <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <select class="form-select" name="BillingType">
                        <option>Prepaid</option>
                        <option>Postpaid</option>
                        <option>Xentronet</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Plan</label>
                    <select class="form-select" name="PlanAmount" id="newPlanAmount" required>
                        @foreach (var planOption in planOptions)
                        {
                            <option value="@planOption.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)">@planOption.ToString("N0")</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Area</label>
                    <select class="form-select" name="Area" id="newArea" required>
                        @foreach (var areaOption in areaOptions)
                        {
                            <option>@areaOption</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Zone</label>
                    <select class="form-select" name="Zone" id="newZone" required>
                        @foreach (var zoneOption in zoneOptions)
                        {
                            <option>@zoneOption</option>
                        }
                    </select>
                </div>
                <div class="col-md-3"><label class="form-label">PPPoE username</label><input class="form-control" name="PppoeUsername" id="newPppoeUsername" /></div>
                <div class="col-md-3"><label class="form-label">Contact number</label><input class="form-control" name="Contact" /></div>
                <div class="col-md-3">
                    <label class="form-label">Referral</label>
                    <input class="form-control" name="Referral" list="referralOptions" value="INQUIRE" autocomplete="off" />
                    <datalist id="referralOptions">
                        <option value="INQUIRE"></option>
                        @foreach (var referralClient in referralClients)
                        {
                            <option value="@($"{referralClient.AccountNumber} - {referralClient.Name}")"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-2"><label class="form-label">Prorated Bill</label><input class="form-control" name="Bills" id="newProratedBill" type="number" step="0.01" readonly /></div>
                <div class="col-md-4"><label class="form-label">Landmark</label><input class="form-control" name="Address" /></div>
                <div class="col-md-2 d-grid align-items-end"><button class="btn btn-primary mt-md-4">Save client</button></div>
            </form>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Name</th><th>Type</th><th>Status</th><th>Plan</th><th>Due</th><th>Area</th><th>Zone</th><th>PPPoE</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var client in Model)
                {
                    var badgeClass = client.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" :
                        client.Status.Equals("DC", StringComparison.OrdinalIgnoreCase) ? "bg-red-lt" : "bg-secondary-lt";
                    var typeBadgeClass = client.BillingType.Equals("Prepaid", StringComparison.OrdinalIgnoreCase) ? "bg-blue-lt" :
                        client.BillingType.Equals("Postpaid", StringComparison.OrdinalIgnoreCase) ? "bg-purple-lt" :
                        client.BillingType.Equals("Xentronet", StringComparison.OrdinalIgnoreCase) ? "bg-orange-lt" : "bg-secondary-lt";
                    billingRules.TryGetValue(client.Id, out var billingRule);
                    var installedOn = client.DateInstalled?.ToString("yyyy-MM-dd") ?? "";
                    var planAmount = client.PlanAmount.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    var balance = client.Balance.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    var advance = client.Advance.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    var bills = client.Bills.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    deleteCaptchas.TryGetValue(client.Id, out var deleteCaptcha);
                    <tr>
                        <td>@client.AccountNumber</td>
                        <td class="fw-medium">
                            <a class="text-reset" asp-action="CustomerAccount" asp-route-id="@client.Id">@client.Name</a>
                        </td>
                        <td>
                            <span class="badge @typeBadgeClass">@client.BillingType</span>
                            @if (billingRule?.HasEarlyDiscount == true)
                            {
                                <div class="small text-secondary">PHP @billingRule.EarlyDiscountAmount.ToString("N0") early discount</div>
                            }
                        </td>
                        <td><span class="badge @badgeClass">@client.Status</span></td>
                        <td>PHP @client.PlanAmount.ToString("N0")</td>
                        <td>
                            <div>@(billingRule?.ScheduleLabel ?? "-")</div>
                            @if (billingRule is not null)
                            {
                                <div class="small text-secondary">@billingRule.NextDueDate.ToString("MMM dd, yyyy")</div>
                            }
                        </td>
                        <td>@client.Area</td>
                        <td>@client.Zone</td>
                        <td><code>@client.PppoeUsername</code></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-outline-secondary"
                                    type="button"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editClientModal"
                                    data-client-id="@client.Id"
                                    data-client-account="@client.AccountNumber"
                                    data-client-installed="@installedOn"
                                    data-client-name="@client.Name"
                                    data-client-status="@client.Status"
                                    data-client-type="@client.BillingType"
                                    data-client-plan="@planAmount"
                                    data-client-area="@client.Area"
                                    data-client-zone="@client.Zone"
                                    data-client-pppoe="@client.PppoeUsername"
                                    data-client-contact="@client.Contact"
                                    data-client-address="@client.Address"
                                    data-client-balance="@balance"
                                    data-client-advance="@advance"
                                    data-client-bills="@bills"
                                    data-client-remarks="@client.Remarks">
                                <i class="ti ti-edit me-1"></i>Edit
                            </button>
                            <a class="btn btn-sm btn-outline-primary" asp-action="ClientHistory" asp-route-id="@client.Id">
                                <i class="ti ti-history me-1"></i>History
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    type="button"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteClientModal"
                                    data-client-id="@client.Id"
                                    data-client-account="@client.AccountNumber"
                                    data-client-name="@client.Name"
                                    data-client-captcha="@deleteCaptcha">
                                <i class="ti ti-trash me-1"></i>Delete
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="editClientModal" tabindex="-1" aria-labelledby="editClientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="SaveClient" method="post">
                <input type="hidden" name="Id" id="editClientId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editClientModalLabel">Edit client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Account #</label>
                            <input class="form-control" id="editAccountNumberDisplay" disabled />
                            <input type="hidden" name="AccountNumber" id="editAccountNumber" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date installed</label>
                            <input class="form-control" id="editDateInstalledDisplay" type="date" disabled />
                            <input type="hidden" name="DateInstalled" id="editDateInstalled" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Client name</label>
                            <input class="form-control" name="Name" id="editName" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="Status" id="editStatus">
                                <option>Active</option>
                                <option>DC</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Type</label>
                            <select class="form-select" name="BillingType" id="editBillingType">
                                <option>Prepaid</option>
                                <option>Postpaid</option>
                                <option>Xentronet</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Plan</label>
                            <select class="form-select" name="PlanAmount" id="editPlanAmount">
                                <option value="800">800</option>
                                <option value="1000">1000</option>
                                <option value="1200">1200</option>
                                <option value="1500">1500</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Area</label>
                            <select class="form-select" name="Area" id="editArea">
                                <option>Asassi</option>
                                <option>Bagunot</option>
                                <option>Bunugan</option>
                                <option>Canagatan</option>
                                <option>Carupian</option>
                                <option>Ibulo</option>
                                <option>Poblacion</option>
                                <option>San Vicente</option>
                                <option>Taguing</option>
                                <option>Temblique</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Zone</label>
                            <select class="form-select" name="Zone" id="editZone">
                                <option>Zone 1</option>
                                <option>Zone 2</option>
                                <option>Zone 3</option>
                                <option>Zone 4</option>
                                <option>Zone 5</option>
                                <option>Zone 6</option>
                                <option>Zone 7</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">PPPoE username</label>
                            <input class="form-control" name="PppoeUsername" id="editPppoeUsername" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Contact number</label>
                            <input class="form-control" name="Contact" id="editContact" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Balance</label>
                            <input class="form-control" name="Balance" id="editBalance" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Advance</label>
                            <input class="form-control" name="Advance" id="editAdvance" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Prorated Bill</label>
                            <input class="form-control" name="Bills" id="editBills" type="number" step="0.01" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Landmark</label>
                            <input class="form-control" name="Address" id="editAddress" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Remarks</label>
                            <input class="form-control" name="Remarks" id="editRemarks" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary">
                        <i class="ti ti-device-floppy me-1"></i>Save changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="clearClientsModal" tabindex="-1" aria-labelledby="clearClientsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ClearClientRecords" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="clearClientsModalLabel">Clear all client records</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger mb-3" role="alert">
                        All clients, payment history, monthly bills, plan changes, PPPoE, traffic, and job records will be removed.
                    </div>
                    <label class="form-label" for="clearClientsConfirmation">
                        Type <strong>CLEAR ALL</strong> to continue.
                    </label>
                    <input class="form-control" name="confirmation" id="clearClientsConfirmation" autocomplete="off" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger">
                        <i class="ti ti-trash me-1"></i>Clear records
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteClientModal" tabindex="-1" aria-labelledby="deleteClientModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="DeleteClient" method="post">
                <input type="hidden" name="id" id="deleteClientId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteClientModalLabel">Delete client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">
                        Delete <strong id="deleteClientName"></strong>
                        <span class="text-secondary" id="deleteClientAccount"></span>?
                    </p>
                    <div class="alert alert-warning mb-3" role="alert">
                        Client, payment history, monthly bills, plan changes, PPPoE, traffic, and job records will be removed.
                    </div>
                    <label class="form-label" for="deleteCaptchaAnswer">
                        Captcha: what is <strong id="deleteCaptchaQuestion"></strong>?
                    </label>
                    <input class="form-control" name="captchaAnswer" id="deleteCaptchaAnswer" inputmode="numeric" autocomplete="off" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger">
                        <i class="ti ti-trash me-1"></i>Delete client
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const areaPrefixes = {
                "Asassi": "ASA-NP",
                "Bagunot": "BGT-NP",
                "Bunugan": "BNG-NP",
                "Canagatan": "CNT-NP",
                "Carupian": "CRP-NP",
                "Ibulo": "IBU-NP",
                "Poblacion": "POB-NP",
                "San Vicente": "SVT-NP",
                "Taguing": "TGG-NP",
                "Temblique": "TEM-NP"
            };
            const newArea = document.getElementById("newArea");
            const newPppoeUsername = document.getElementById("newPppoeUsername");
            const newPlanAmount = document.getElementById("newPlanAmount");
            const newDateInstalled = document.getElementById("newDateInstalled");
            const newProratedBill = document.getElementById("newProratedBill");
            let lastPppoePrefix = "";

            function syncPppoePrefix() {
                if (!newArea || !newPppoeUsername) {
                    return;
                }

                const prefix = areaPrefixes[newArea.value] || "";
                const current = newPppoeUsername.value.trim();
                if (!current || current === lastPppoePrefix) {
                    newPppoeUsername.value = prefix;
                } else if (lastPppoePrefix && current.toUpperCase().startsWith(lastPppoePrefix)) {
                    newPppoeUsername.value = prefix + current.substring(lastPppoePrefix.length);
                }

                lastPppoePrefix = prefix;
            }

            function syncProratedBill() {
                if (!newPlanAmount || !newDateInstalled || !newProratedBill) {
                    return;
                }

                const plan = Number.parseFloat(newPlanAmount.value || "0");
                if (!plan || !newDateInstalled.value) {
                    newProratedBill.value = "";
                    return;
                }

                const installed = new Date(`${newDateInstalled.value}T00:00:00`);
                if (Number.isNaN(installed.getTime())) {
                    newProratedBill.value = "";
                    return;
                }

                const daysInMonth = new Date(installed.getFullYear(), installed.getMonth() + 1, 0).getDate();
                const billableDays = Math.max(0, daysInMonth - installed.getDate() + 1);
                const amount = Math.round((plan / daysInMonth * billableDays + Number.EPSILON) * 100) / 100;
                newProratedBill.value = amount.toFixed(2);
            }

            if (newArea) {
                newArea.addEventListener("change", syncPppoePrefix);
                syncPppoePrefix();
            }

            if (newPlanAmount) {
                newPlanAmount.addEventListener("change", syncProratedBill);
            }

            if (newDateInstalled) {
                newDateInstalled.addEventListener("change", syncProratedBill);
            }

            syncProratedBill();

            const modal = document.getElementById("editClientModal");
            const fieldMap = {
                clientId: "editClientId",
                clientAccount: "editAccountNumber",
                clientInstalled: "editDateInstalled",
                clientName: "editName",
                clientStatus: "editStatus",
                clientType: "editBillingType",
                clientPlan: "editPlanAmount",
                clientArea: "editArea",
                clientZone: "editZone",
                clientPppoe: "editPppoeUsername",
                clientContact: "editContact",
                clientAddress: "editAddress",
                clientBalance: "editBalance",
                clientAdvance: "editAdvance",
                clientBills: "editBills",
                clientRemarks: "editRemarks"
            };

            modal.addEventListener("show.bs.modal", function (event) {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                for (const key in fieldMap) {
                    const field = document.getElementById(fieldMap[key]);
                    if (field) {
                        field.value = button.dataset[key] || "";
                    }
                }

                const accountDisplay = document.getElementById("editAccountNumberDisplay");
                if (accountDisplay) {
                    accountDisplay.value = button.dataset.clientAccount || "";
                }

                const installedDisplay = document.getElementById("editDateInstalledDisplay");
                if (installedDisplay) {
                    installedDisplay.value = button.dataset.clientInstalled || "";
                }
            });

            const deleteModal = document.getElementById("deleteClientModal");
            deleteModal.addEventListener("show.bs.modal", function (event) {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                document.getElementById("deleteClientId").value = button.dataset.clientId || "";
                document.getElementById("deleteClientName").textContent = button.dataset.clientName || "";
                document.getElementById("deleteClientAccount").textContent = button.dataset.clientAccount ? `#${button.dataset.clientAccount}` : "";
                document.getElementById("deleteCaptchaQuestion").textContent = button.dataset.clientCaptcha || "";
                document.getElementById("deleteCaptchaAnswer").value = "";
            });
        });
    </script>
}
