@model IReadOnlyList<ClientCurrentBillRow>
@{
    ViewData["Title"] = "Payments";
    var clients = ViewBag.Clients as IReadOnlyList<Client> ?? Array.Empty<Client>();
    var billingRules = ViewBag.ClientBillingRules as IReadOnlyDictionary<int, BillingRuleInfo> ?? new Dictionary<int, BillingRuleInfo>();
    var currentBills = ViewBag.ClientCurrentBills as IReadOnlyDictionary<int, decimal> ?? new Dictionary<int, decimal>();
    var clientPppoeStatuses = ViewBag.ClientPppoeStatuses as IReadOnlyDictionary<int, string> ?? new Dictionary<int, string>();
    var invariantCulture = System.Globalization.CultureInfo.InvariantCulture;
    var selectedMonthValue = ViewBag.SelectedMonthValue as string ?? DateTime.Today.ToString("yyyy-MM");
    var selectedMonthLabel = ViewBag.SelectedMonthLabel as string ?? DateTime.Today.ToString("MMMM yyyy");
    var collectorName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="page-title h3 mb-1">Payments</h1>
        <p class="text-body-secondary mb-0">Record cash, GCash, bank, and collector payments.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#monthlyReportModal">
            <i class="ti ti-file-spreadsheet me-1"></i>Monthly report
        </button>
        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#summaryReportModal">
            <i class="ti ti-download me-1"></i>Summary
        </button>
        <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addPaymentModal">
            <i class="ti ti-plus me-1"></i>Add payment
        </button>
    </div>
</div>

<div class="modal fade" id="monthlyReportModal" tabindex="-1" aria-labelledby="monthlyReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <form asp-action="DownloadMonthlyPayments" method="get" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="monthlyReportModalLabel">Monthly report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Month</label>
                <input class="form-control" type="month" name="month" value="@selectedMonthValue" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-sm btn-primary">
                    <i class="ti ti-file-spreadsheet me-1"></i>Download
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="summaryReportModal" tabindex="-1" aria-labelledby="summaryReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <form asp-action="DownloadPaymentsSummary" method="get" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="summaryReportModalLabel">Payment summary</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0 text-secondary">Download the full payment summary workbook.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-sm btn-primary">
                    <i class="ti ti-download me-1"></i>Download
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="addPaymentModal" tabindex="-1" aria-labelledby="addPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <form asp-action="AddPayment" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addPaymentModalLabel">Add payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-lg-4">
                        <label class="form-label">Client</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="ti ti-search"></i></span>
                            <input class="form-control" id="paymentClientSearch" type="search" list="paymentClientSuggestions" placeholder="Search client name" autocomplete="off" required />
                        </div>
                        <input type="hidden" id="paymentClientId" name="ClientId" />
                        <datalist id="paymentClientSuggestions">
                            @foreach (var client in clients)
                            {
                                billingRules.TryGetValue(client.Id, out var rule);
                                var currentBill = currentBills.TryGetValue(client.Id, out var billAmount) ? billAmount : client.Bills;
                                <option value="@($"{client.Name} - {client.PppoeUsername} - #{client.AccountNumber}")"
                                        data-client-id="@client.Id"
                                        data-billing-type="@(rule?.BillingType ?? client.BillingType)"
                                        data-client-search="@($"{client.Name} {client.AccountNumber} {client.PppoeUsername}")"
                                        data-schedule="@(rule?.ScheduleLabel ?? "")"
                                        data-due="@(rule?.NextDueDate.ToString("MMM dd, yyyy") ?? "")"
                                        data-current-bill="@currentBill.ToString("0.##", invariantCulture)"
                                        data-has-discount="@((rule?.HasEarlyDiscount == true).ToString().ToLowerInvariant())"
                                        data-discount="@((rule?.EarlyDiscountAmount ?? 0).ToString("0.##"))"
                                        data-deadline="@(rule?.DiscountDeadline?.ToString("MMM dd, yyyy") ?? "")"
                                        data-deadline-iso="@(rule?.DiscountDeadline?.ToString("yyyy-MM-dd") ?? "")"></option>
                            }
                        </datalist>
                    </div>
                    <div class="col-md-2"><label class="form-label">Date</label><input class="form-control" id="paymentDate" name="PaidOn" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
                    <div class="col-md-2"><label class="form-label">Amount</label><input class="form-control" id="paymentAmount" name="Amount" type="number" step="0.01" required /></div>
                    <div class="col-md-2"><label class="form-label">Method</label><select class="form-select" name="Method"><option>Cash</option><option>GCash</option><option>Bank</option></select></div>
                    <div class="col-md-4"><label class="form-label">Reference number</label><input class="form-control" name="ReferenceNumber" /></div>
                    <div class="col-md-4"><label class="form-label">Collected by</label><input class="form-control" name="CollectedBy" value="@collectorName" readonly /></div>
                    <div class="col-md-4"><label class="form-label">Remarks</label><input class="form-control" name="Remarks" /></div>
                    <div class="col-12">
                        <div id="billingRuleInfo" class="alert alert-info d-none mb-0" role="alert"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="form-check me-auto">
                    <input class="form-check-input" id="printThermalAfterPayment" name="printThermal" type="checkbox" value="true" />
                    <label class="form-check-label" for="printThermalAfterPayment">Print thermal after saving</label>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-sm btn-primary">
                    <i class="ti ti-plus me-1"></i>Add payment
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <span class="fw-semibold">CLIENT LIST</span>
            <span class="badge text-bg-light border ms-2">@selectedMonthLabel</span>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <div class="input-group input-group-sm" style="max-width: 260px;">
                <span class="input-group-text"><i class="ti ti-search"></i></span>
                <input class="form-control" id="paymentSearchInput" type="search" placeholder="Search payment" autocomplete="off" />
            </div>
            <form asp-action="Payments" method="get" class="d-flex align-items-center gap-2">
                <label class="small text-secondary mb-0" for="recordsMonth">Month</label>
                <input class="form-control form-control-sm" id="recordsMonth" type="month" name="month" value="@selectedMonthValue" onchange="this.form.submit()" />
            </form>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Client</th>
                        <th>Type</th>
                        <th>Client status</th>
                        <th>Due date</th>
                        <th class="text-end">Previous balance</th>
                        <th class="text-end">Advance</th>
                        <th class="text-end">Referral</th>
                        <th class="text-end">Current bill</th>
                        <th class="text-end">Amount Paid</th>
                        <th class="text-end">Balance after paid</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model)
                {
                    var client = row.Client;
                    var statusClass = row.Status.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "bg-green-lt" :
                        row.Status.Equals("Partial", StringComparison.OrdinalIgnoreCase) ? "bg-yellow-lt" :
                        row.Status.Equals("Unpaid", StringComparison.OrdinalIgnoreCase) ? "bg-red-lt" : "bg-secondary-lt";
                    var clientPppoeStatus = clientPppoeStatuses.TryGetValue(client.Id, out var pppoeStatus)
                        ? pppoeStatus
                        : "DISCONNECTED (EXPIRED)";
                    var clientStatusClass = clientPppoeStatus.Equals("ACTIVE", StringComparison.OrdinalIgnoreCase)
                        ? "bg-green-lt"
                        : "bg-red-lt";
                    <tr class="payment-current-bill-row"
                        data-customer-account-url="@Url.Action("CustomerAccount", new { id = client.Id })"
                        data-search="@($"{client.AccountNumber} {client.Name} {client.PppoeUsername} {client.BillingType} {clientPppoeStatus} {row.DueDate:MMM dd, yyyy} {row.ReferralNames} {row.Status}")"
                        tabindex="0"
                        role="link"
                        title="Open customer account">
                        <td>@client.AccountNumber</td>
                        <td>
                            <div class="fw-medium">@client.Name</div>
                            <div class="small text-secondary">@client.PppoeUsername</div>
                        </td>
                        <td>@client.BillingType</td>
                        <td><span class="badge @clientStatusClass">@clientPppoeStatus</span></td>
                        <td>@row.DueDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">@(row.PreviousBalance > 0 ? $"PHP {row.PreviousBalance:N0}" : "-")</td>
                        <td class="text-end">@(row.Advance > 0 ? $"PHP {row.Advance:N0}" : "-")</td>
                        <td class="text-end">
                            @if (row.ReferralDiscount > 0 || !string.IsNullOrWhiteSpace(row.ReferralNames))
                            {
                                <div>@(row.ReferralDiscount > 0 ? $"PHP {row.ReferralDiscount:N0}" : "-")</div>
                                @if (!string.IsNullOrWhiteSpace(row.ReferralNames))
                                {
                                    <div class="small text-secondary">@row.ReferralNames</div>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td class="text-end">PHP @row.CurrentBill.ToString("N0")</td>
                        <td class="text-end">@(row.PaidThisMonth > 0 ? $"PHP {row.PaidThisMonth:N0}" : "-")</td>
                        <td class="text-end">@(row.Balance > 0 ? $"PHP {row.Balance:N0}" : "-")</td>
                        <td><span class="badge @statusClass">@row.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const addPaymentForm = document.querySelector("#addPaymentModal form");
            const clientInput = document.getElementById("paymentClientSearch");
            const clientIdInput = document.getElementById("paymentClientId");
            const clientOptions = Array.from(document.querySelectorAll("#paymentClientSuggestions option"));
            const paymentDate = document.getElementById("paymentDate");
            const amountInput = document.getElementById("paymentAmount");
            const info = document.getElementById("billingRuleInfo");
            const searchInput = document.getElementById("paymentSearchInput");
            const paymentRows = Array.from(document.querySelectorAll(".payment-current-bill-row"));
            let lastSuggestedAmount = "";

            paymentRows.forEach(function (row) {
                row.style.cursor = "pointer";

                row.addEventListener("click", function (event) {
                    if (event.target.closest("button, a, input, select, textarea, label")) {
                        return;
                    }

                    if (row.dataset.customerAccountUrl) {
                        window.location.href = row.dataset.customerAccountUrl;
                    }
                });

                row.addEventListener("keydown", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") {
                        return;
                    }

                    if (row.dataset.customerAccountUrl) {
                        event.preventDefault();
                        window.location.href = row.dataset.customerAccountUrl;
                    }
                });
            });

            function normalizeText(value) {
                return (value || "").toString().toLowerCase().trim();
            }

            if (searchInput) {
                searchInput.addEventListener("input", function () {
                    const query = normalizeText(searchInput.value);
                    paymentRows.forEach(function (row) {
                        const searchText = normalizeText(row.dataset.search || row.textContent);
                        row.classList.toggle("d-none", query.length > 0 && !searchText.includes(query));
                    });
                });
            }

            function selectedClientOption() {
                if (!clientInput) {
                    return null;
                }

                const inputValue = normalizeText(clientInput.value);
                return clientOptions.find(function (option) {
                    return normalizeText(option.value) === inputValue;
                }) || null;
            }

            function syncSelectedClient() {
                const selected = selectedClientOption();
                if (clientIdInput) {
                    clientIdInput.value = selected?.dataset.clientId || "";
                }

                if (clientInput) {
                    clientInput.setCustomValidity(clientInput.value && !selected ? "Choose a client from the suggestions." : "");
                }

                updateBillingRuleInfo();
            }

            function money(value) {
                return new Intl.NumberFormat("en-PH", { maximumFractionDigits: 0 }).format(Number(value || 0));
            }

            function updateBillingRuleInfo() {
                if (!clientInput || !paymentDate || !amountInput || !info) {
                    return;
                }

                const selected = selectedClientOption();
                if (!selected) {
                    info.className = "alert alert-info d-none mb-0";
                    info.textContent = "";
                    return;
                }

                const hasDiscount = selected.dataset.hasDiscount === "true";
                const currentBill = Number(selected.dataset.currentBill || 0);
                const discount = Number(selected.dataset.discount || 0);
                const paidBeforeDeadline = hasDiscount
                    && paymentDate.value
                    && selected.dataset.deadlineIso
                    && paymentDate.value < selected.dataset.deadlineIso;
                const suggestedBill = currentBill;

                info.className = "alert " + (hasDiscount && paidBeforeDeadline ? "alert-warning" : "alert-info") + " mb-0";
                info.innerHTML = hasDiscount && paidBeforeDeadline
                    ? "<strong>Xentronet discount eligible:</strong> PHP " + money(discount) + " before " + selected.dataset.deadline + ". Admin can apply it from the customer account current bill. Suggested amount: <strong>PHP " + money(suggestedBill) + "</strong>."
                    : hasDiscount
                    ? "<strong>Xentronet:</strong> prepaid every 1st day. Discount is available only before " + selected.dataset.deadline + " when admin applies it. Suggested amount: <strong>PHP " + money(suggestedBill) + "</strong>."
                    : "<strong>" + selected.dataset.billingType + ":</strong> " + selected.dataset.schedule + ". Next due: " + selected.dataset.due + ". Suggested amount: <strong>PHP " + money(suggestedBill) + "</strong>.";

                if ((!amountInput.value || amountInput.value === lastSuggestedAmount) && suggestedBill > 0) {
                    amountInput.value = suggestedBill.toFixed(2);
                    lastSuggestedAmount = amountInput.value;
                }
            }

            clientInput?.addEventListener("input", syncSelectedClient);
            clientInput?.addEventListener("change", syncSelectedClient);
            paymentDate?.addEventListener("change", updateBillingRuleInfo);
            addPaymentForm?.addEventListener("submit", function (event) {
                syncSelectedClient();
                if (!clientIdInput?.value) {
                    event.preventDefault();
                    clientInput?.reportValidity();
                }
            });
            updateBillingRuleInfo();
        });
    </script>
}
